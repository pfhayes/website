#!/usr/bin/env bash

set -e
set -o pipefail

if [[ "$(uname)" != "Linux" ]]; then
  echo >&2 "Error: script/setup must be run on the remote machine."
  exit 1
fi

SOURCE_DIR=/home/ubuntu/website
RESOURCES_DIR=/home/ubuntu/website/resources
ENVIRONMENT_FILE="$RESOURCES_DIR/environment-vars"
set -a
source $ENVIRONMENT_FILE
set +a
{
  echo "source $ENVIRONMENT_FILE"
  echo 'export PATH="$HOME/.rbenv/bin:$PATH"'
  echo 'eval "$(rbenv init - bash)"'
} > /home/ubuntu/.bash_profile

id -u patrick &>/dev/null || sudo useradd patrick

# Configure sources
sudo mkdir -p /etc/apt/keyrings
curl -fsSL https://dl.yarnpkg.com/debian/pubkey.gpg | sudo gpg --batch --yes --dearmor -o /etc/apt/keyrings/yarn.gpg
sudo install -T "$RESOURCES_DIR/yarn.list" /etc/apt/sources.list.d/yarn.list

# Install packages
sudo DEBIAN_FRONTEND=noninteractive apt-get update -yq
sudo DEBIAN_FRONTEND=noninteractive apt-get dist-upgrade -yq
sudo DEBIAN_FRONTEND=noninteractive apt-get install -yq \
  autoconf \
  g++ \
  gcc \
  git \
  libffi-dev \
  libgmp-dev \
  libpq-dev \
  libreadline-dev \
  libssl-dev \
  libxml2-dev \
  libyaml-dev \
  make \
  nginx \
  nodejs \
  patch \
  software-properties-common \
  yarn \
  zlib1g-dev
sudo DEBIAN_FRONTEND=noninteractive apt-get remove certbot -yq
sudo snap install --classic certbot
sudo snap set certbot trust-plugin-with-root=ok
sudo snap install certbot-dns-cloudflare
sudo snap connect certbot:plugin certbot-dns-cloudflare
sudo snap install core
sudo snap refresh core
sudo apt autoremove -yq

# config files
sudo rm -f /etc/nginx/sites-enabled/default
sudo install -T resources/nginx-parent.conf /etc/nginx/nginx.conf
sudo install -T resources/patrick-web.service /etc/systemd/system/patrick-web.service

# certs — DNS-01 via Cloudflare. /etc/letsencrypt/cloudflare.ini is placed by
# script/provision on fresh servers and persists across deploys.
if sudo test -d /etc/letsencrypt/live/patrickhay.es; then
  sudo certbot renew
else
  sudo certbot certonly \
    --dns-cloudflare \
    --dns-cloudflare-credentials /etc/letsencrypt/cloudflare.ini \
    -d patrickhay.es \
    --non-interactive \
    --agree-tos \
    --email p@phay.es
fi

sudo install -T resources/nginx.conf /etc/nginx/sites-enabled/patrick-web.conf
sudo nginx -t

# cron
"$RESOURCES_DIR/cron/verify-all"
sudo install -T "$RESOURCES_DIR/cron/weekly" /etc/cron.weekly/patrick-web

# systemctl
sudo systemctl enable patrick-web
sudo systemctl daemon-reload

# logging
rm -rf "$SOURCE_DIR/log"
sudo touch /var/log/patrick-web.log
sudo chown patrick /var/log/patrick-web.log

# swap - small instances need it to compile ruby and native gems
SWAPFILE=/swapfile
if [ ! -f "$SWAPFILE" ]; then
  sudo fallocate -l 1G "$SWAPFILE"
  sudo chmod 600 "$SWAPFILE"
  sudo mkswap "$SWAPFILE"
  sudo swapon "$SWAPFILE"
fi

# ruby - rbenv + ruby-build, pinned by .ruby-version
export RBENV_ROOT="$HOME/.rbenv"
if [[ ! -d "$RBENV_ROOT" ]]; then
  git clone https://github.com/rbenv/rbenv.git "$RBENV_ROOT"
else
  git -C "$RBENV_ROOT" pull --ff-only
fi
if [[ ! -d "$RBENV_ROOT/plugins/ruby-build" ]]; then
  git clone https://github.com/rbenv/ruby-build.git "$RBENV_ROOT/plugins/ruby-build"
else
  git -C "$RBENV_ROOT/plugins/ruby-build" pull --ff-only
fi
export PATH="$RBENV_ROOT/bin:$PATH"
eval "$(rbenv init - bash)"
rbenv install --skip-existing "$(cat "$SOURCE_DIR/.ruby-version")"

gem update --system  # ships a matching default bundler
bundle install

# rails
sudo chmod a+x /home/ubuntu  # Allow `patrick` to cd into $SOURCE_DIR
export RAILS_ENV=production
bundle exec rake assets:precompile
SECRET_KEY_FILE="$RESOURCES_DIR/secret-key"
if [ ! -f "$SECRET_KEY_FILE" ]; then
  echo "SECRET_KEY_BASE=$(bundle exec rails secret)" > "$SECRET_KEY_FILE"
fi

# restart
sudo service patrick-web restart
sudo service nginx restart

if [ -f /var/run/reboot-required ]; then
  echo "Reboot required — rebooting in 5 seconds."
  (sleep 5 && sudo reboot) &
fi
